<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PurcariDesktop.MainWindow"
        Width="1000" Height="650"
        Title="Purcari Desktop - Wines CRUD"
        xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid">

  <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="10">

    <!-- FORM -->
    <Border Grid.Row="0" Padding="12" CornerRadius="10" BorderBrush="Gray" BorderThickness="1">
      <Grid ColumnDefinitions="*,*,*,*,Auto,Auto,Auto,Auto"
            RowDefinitions="Auto,Auto"
            ColumnSpacing="8" RowSpacing="8">

        <TextBlock Text="Name" />
        <TextBlock Grid.Column="1" Text="Type" />
        <TextBlock Grid.Column="2" Text="Price" />
        <TextBlock Grid.Column="3" Text="Year" />

        <TextBox Grid.Row="1" Text="{Binding NameInput, Mode=TwoWay}" />
        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding TypeInput, Mode=TwoWay}" />
        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding PriceInput, Mode=TwoWay}" />
        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding YearInput, Mode=TwoWay}" />

        <Button Grid.Row="1" Grid.Column="4" Content="Add" Click="AddCommand"/>
        <Button Grid.Row="1" Grid.Column="5" Content="Update" Click="UpdateCommand"/>
        <Button Grid.Row="1" Grid.Column="6" Content="Delete" Click="DeleteCommand"/>
        <Button Grid.Row="1" Grid.Column="7" Content="Refresh" Click="RefreshCommand"/>
      </Grid>
    </Border>

    <!-- STATUS -->
    <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" FontSize="14" Margin="5"/>

    <!-- SEARCH + SUGGESTIONS -->
    <Grid Grid.Row="2"
          RowDefinitions="Auto,Auto"
          ColumnDefinitions="Auto,*,Auto,Auto"
          ColumnSpacing="8" RowSpacing="6">

      <TextBlock Grid.Row="0" VerticalAlignment="Center" Text="Search:"/>

      <TextBox Grid.Row="0" Grid.Column="1"
               Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               Watermark="caută după name/type..." />
      <Button Content="Generate Report (PDF+Excel)" Click="GenerateReportCommand" Margin="0,50,0,0"/>
      <Button Grid.Row="0" Grid.Column="2" Content="Apply" Click="SearchCommand"/>
      <Button Grid.Row="0" Grid.Column="3" Content="Clear" Click="ClearSearchCommand"/>
    
      <!-- SUGGESTIONS LIST -->
      <ListBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3"
               ItemsSource="{Binding SearchSuggestions}"
               SelectedItem="{Binding SelectedSuggestion, Mode=TwoWay}"
               IsVisible="{Binding HasSuggestions}"
               MaxHeight="180">

        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border Padding="8" CornerRadius="8" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,6">
              <StackPanel>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Type}" Opacity="0.7"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>

      </ListBox>
    </Grid>

    <!-- COUNT -->
    <TextBlock Grid.Row="3"
               Text="{Binding ResultsCount, StringFormat=Rezultate găsite: {0}}"/>

    <!-- DATA GRID -->
    <dg:DataGrid Grid.Row="4"
                 ItemsSource="{Binding Wines}"
                 SelectedItem="{Binding SelectedWine, Mode=TwoWay}"
                 AutoGenerateColumns="False"
                 IsReadOnly="True">

      <dg:DataGrid.Columns>
        <dg:DataGridTextColumn Header="Id" Binding="{Binding WineId}" Width="80"/>
        <dg:DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
        <dg:DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="200"/>
        <dg:DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="120"/>
        <dg:DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="120"/>
      </dg:DataGrid.Columns>

    </dg:DataGrid>

  </Grid>
</Window>
